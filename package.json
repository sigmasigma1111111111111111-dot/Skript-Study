{
  "name": "script-study",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\"",
    "dev:frontend": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
    "build": "vite build && cd server && npm install",
    "start": "node server/index.js",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.26.1",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
